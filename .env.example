# Environment variables for Pearl Drumming Bot
# Copy this file to .env and fill in your actual values

# Required: Platform URL
PLATFORM_URL=https://your-platform-url.com

# Required: Platform login credentials
PLATFORM_USERNAME=your_username
PLATFORM_PASSWORD=your_password

# Required: Invitation code
INVITATION_CODE=iVMvVyYj

# Optional: Account number (default: PH1037)
ACCOUNT_NUMBER=PH1037

# Optional: Drummer name (default: Garry)
DRUMMER_NAME=Garry