# Environment variables for Pearl Drumming Bot
# Copy this file to .env and fill in your actual values

# Required: Platform URL
PLATFORM_URL=https://your-platform-url.com

# Required: Platform login credentials
PLATFORM_USERNAME=your_username
PLATFORM_PASSWORD=your_password

# Required: Invitation code
INVITATION_CODE=iVMvVyYj

# Optional: Account number (default: PH1037)
ACCOUNT_NUMBER=PH1037

# Optional: Drummer name (default: Garry)
DRUMMER_NAME=Garry

# ----------------------------
# LLM (Required)
# ----------------------------
# Used by config.LLMConfig (required) and services/llm_services.py
LLM_API_KEY=your_llm_api_key

# Optional model + base URL (defaults are set in config.py)
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1/chat/completions

# ----------------------------
# Google Sheets (Required)
# ----------------------------
GOOGLE_SHEET_ID=your_google_sheet_id

# Optional (defaults are set in config.py)
GOOGLE_SHEET_NAME=Sheet1
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service_account.json
GOOGLE_SHEET_URL=

# ----------------------------
# WebDriver / Runtime (Optional)
# ----------------------------
HEADLESS=false
BROWSER_TIMEOUT=30
IMPLICIT_WAIT=10
PAGE_LOAD_TIMEOUT=60

MAX_RETRIES=3
RETRY_DELAY=2

LOG_LEVEL=INFO
LOG_FILE=logs/automation.log

# ----------------------------
# Social Media Credentials (Optional)
# ----------------------------
REDDIT_USERNAME=
REDDIT_PASSWORD=

QUORA_EMAIL=
QUORA_PASSWORD=

LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

FACEBOOK_EMAIL=
FACEBOOK_PASSWORD=

YOUTUBE_EMAIL=
YOUTUBE_PASSWORD=

TIKTOK_USERNAME=
TIKTOK_PASSWORD=

INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

PINTEREST_EMAIL=
PINTEREST_PASSWORD=
